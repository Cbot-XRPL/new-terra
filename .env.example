# --- Server ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/new_terra?schema=public
PORT=4000
NODE_ENV=development

# JWT secret — generate one: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Public URL of the client app (used in invite emails)
APP_URL=http://localhost:5173

# Bootstrap admin (created by `npm run db:seed` if no admin exists)
SEED_ADMIN_EMAIL=admin@newterraconstruction.com
SEED_ADMIN_PASSWORD=changeMe!2026
SEED_ADMIN_NAME=Site Admin

# --- Email (optional; if unset, invite links are logged to the server console) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="New Terra Construction <no-reply@newterraconstruction.com>"

# Recipient for public contact form submissions (defaults to sales@…)
INQUIRY_TO=sales@newterraconstruction.com

# Cron expression for the daily stale-contract reminder. Leave blank to
# disable (admin can still trigger manually from the sales-flow widget).
# Example: "0 9 * * *" runs every day at 9:00am server-local time.
CONTRACT_REMINDER_CRON=

# --- DocuSign (optional; "Send via DocuSign" runs in stub mode if unset) ---
# Set every var below + add the Connect webhook pointing to
# https://<your-host>/api/webhooks/docusign with HMAC enabled.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE=account-d.docusign.com
# Paste the full PEM (including BEGIN/END lines). Use \n for newlines or wrap
# the value in single quotes so the key survives env-file parsing.
DOCUSIGN_RSA_PRIVATE_KEY=
# Connect HMAC secret (recommended in prod). Webhooks pass without verification
# when this is unset, which is fine for local development.
DOCUSIGN_HMAC_KEY=

# --- Cloudflare Turnstile (optional captcha on the public contact form) ---
# Set both to enable; leave blank to disable verification.
TURNSTILE_SECRET_KEY=
# Client-side key goes in client/.env as VITE_TURNSTILE_SITE_KEY=...

# --- Image storage (default 'local'; set to 's3' to use S3) ---
# STORAGE_DRIVER=local
# S3_REGION=us-east-1
# S3_BUCKET=new-terra-uploads
# S3_PUBLIC_URL=https://cdn.example.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Client (Vite reads VITE_-prefixed vars from client/.env) ---
# Place this in client/.env, not here:
# VITE_API_URL=http://localhost:4000
