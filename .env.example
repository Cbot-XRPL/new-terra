# --- Server ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/new_terra?schema=public
PORT=4000
NODE_ENV=development

# JWT secret — generate one: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Public URL of the client app (used in invite emails)
APP_URL=http://localhost:5173

# Bootstrap admin (created by `npm run db:seed` if no admin exists)
SEED_ADMIN_EMAIL=admin@newterraconstruction.com
SEED_ADMIN_PASSWORD=changeMe!2026
SEED_ADMIN_NAME=Site Admin

# --- Email (optional; if unset, invite links are logged to the server console) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="New Terra Construction <no-reply@newterraconstruction.com>"

# Recipient for public contact form submissions (defaults to sales@…)
INQUIRY_TO=sales@newterraconstruction.com

# Cron expression for the daily stale-contract reminder. Leave blank to
# disable (admin can still trigger manually from the sales-flow widget).
# Example: "0 9 * * *" runs every day at 9:00am server-local time.
CONTRACT_REMINDER_CRON=
# Same idea for stale leads — emails the assigned rep when a lead has sat
# in NEW/CONTACTED/QUALIFIED/QUOTE_SENT for >5 days without movement.
# Example: "0 8 * * 1-5" fires 8am Mon–Fri.
STALE_LEAD_CRON=
# Invoice reminders — flips SENT → OVERDUE once dueAt passes and emails
# customers about upcoming-due (next 3 days) and overdue invoices. Cooldown
# is 3 days inside the helper so a single invoice never gets emailed more
# than ~twice a week. Example: "0 9 * * 1-5" runs every weekday at 9am.
INVOICE_REMINDER_CRON=

# --- DocuSign (optional; "Send via DocuSign" runs in stub mode if unset) ---
# Set every var below + add the Connect webhook pointing to
# https://<your-host>/api/webhooks/docusign with HMAC enabled.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE=account-d.docusign.com
# Paste the full PEM (including BEGIN/END lines). Use \n for newlines or wrap
# the value in single quotes so the key survives env-file parsing.
DOCUSIGN_RSA_PRIVATE_KEY=
# Connect HMAC secret (recommended in prod). Webhooks pass without verification
# when this is unset, which is fine for local development.
DOCUSIGN_HMAC_KEY=

# --- Stripe (optional — auto-marks invoices PAID on payment) ---
# Set the webhook secret from your Stripe dashboard webhook settings, then
# point Stripe at https://<your-host>/api/webhooks/stripe. Make sure the
# Payment Link or Checkout Session attaches metadata.invoiceId = <our id>
# so the webhook can resolve back to the right invoice. When unset, signature
# verification is skipped — fine for local curl-driven testing only.
STRIPE_WEBHOOK_SECRET=
# Restricted secret key (rk_…) for Payment Link generation. Without this,
# the "Generate payment link" button on invoices runs in stub mode.
STRIPE_SECRET_KEY=

# --- Cloudflare Turnstile (optional captcha on the public contact form) ---
# Set both to enable; leave blank to disable verification.
TURNSTILE_SECRET_KEY=
# Client-side key goes in client/.env as VITE_TURNSTILE_SITE_KEY=...

# --- At-rest encryption for QB tokens ---
# 32 random bytes, base64-encoded (e.g. node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))").
# When unset we derive a key from JWT_SECRET — fine for dev, but production
# should set this so token rotation is independent of session signing.
QB_ENCRYPTION_KEY=

# --- QuickBooks Online (optional accounting integration) ---
# When unset, the finance dashboard works in "local-only" mode — every
# expense stays in our DB without ever touching QB. When set, accountants
# can connect via OAuth from /portal/finance/qb and push expenses on demand.
# Create an app at https://developer.intuit.com → My Apps → Create.
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:4000/api/integrations/quickbooks/callback
# 'sandbox' (default) for the demo company, 'production' once you go live.
QB_ENVIRONMENT=sandbox

# --- Image storage (default 'local'; set to 's3' to use S3) ---
# STORAGE_DRIVER=local
# S3_REGION=us-east-1
# S3_BUCKET=new-terra-uploads
# S3_PUBLIC_URL=https://cdn.example.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Client (Vite reads VITE_-prefixed vars from client/.env) ---
# Place this in client/.env, not here:
# VITE_API_URL=http://localhost:4000
