// New Terra Construction — database schema
// Run: npm run db:migrate
// See server/prisma/seed.ts for the bootstrap admin.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
  SUBCONTRACTOR
  CUSTOMER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum SelectionStatus {
  PENDING
  APPROVED
  CHANGE_REQUESTED
}

enum MembershipTier {
  STANDARD
  PRIORITY
  PREMIER
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  DECLINED
  VOID
}

enum ContractDelivery {
  PORTAL
  DOCUSIGN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  QUOTE_SENT
  WON
  LOST
  ON_HOLD
}

enum LeadSource {
  WEBSITE_FORM
  REFERRAL
  REPEAT_CUSTOMER
  GOOGLE
  ANGI
  HOME_DEPOT
  WALK_IN
  OTHER
}

enum ProjectStatus {
  PLANNING
  AWAITING_CONTRACT
  ACTIVE
  ON_HOLD
  COMPLETE
  CANCELLED
}

// LOCAL_ONLY — entered in our app, no external sync attempted (default).
// QUEUED    — flagged for the next sync run (e.g. when QB OAuth is connected).
// SYNCED    — round-tripped to the integration; qb*Id fields populated.
// ERROR     — last sync attempt failed; lastSyncError holds the message.
//
// We never block expense entry on a sync — these states are advisory so the
// finance dashboard can show pending vs. failed items without fragile coupling.
enum ExpenseSyncStatus {
  LOCAL_ONLY
  QUEUED
  SYNCED
  ERROR
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name          String
  phone         String?
  role          Role
  // Employees flagged as sales get access to the contract portal in addition
  // to their normal employee permissions. Toggleable by admin.
  isSales       Boolean  @default(false)
  // Employees flagged as project managers see a richer project workspace
  // for the projects they're assigned to (status, schedule, photos, logs,
  // selections, invoices, comments). Toggleable by admin.
  isProjectManager Boolean @default(false)
  // Employees flagged as accounting see the finance dashboard, all expenses,
  // and can manage vendors + expense categories. Toggleable by admin.
  isAccounting  Boolean  @default(false)
  isActive      Boolean  @default(true)
  // Bumped on password reset, role change, and admin "sign out everywhere".
  // The auth middleware compares this against the JWT claim and rejects
  // tokens whose version is stale — that's how we revoke without a session
  // table.
  tokenVersion  Int      @default(0)
  // Profile picture — main display image (512px webp) and a small
  // thumbnail (96px webp) used in the nav bar and dense lists. Both URLs
  // are produced by the avatar upload pipeline (sharp resize).
  avatarUrl     String?
  avatarThumbnailUrl String?
  // Tax filing fields — only relevant for subcontractors (used by the 1099
  // export). All optional so existing users can leave them blank; the
  // export skips subs missing data so admin sees what's incomplete.
  taxId         String?
  mailingAddress String?  // multi-line OK
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Customer-side relations
  projects      Project[]       @relation("CustomerProjects")
  invoices      Invoice[]
  selections    Selection[]
  membership    Membership?

  // Staff who recorded payments (bookkeeping audit trail).
  paymentsRecorded Payment[] @relation("RecordedPayments")

  // Change orders authored by this user (admin/PM/sales).
  changeOrdersAuthored ChangeOrder[] @relation("ChangeOrdersAuthored")

  // Recurring invoice templates. Customers see them as "billed to me",
  // staff (admin/accounting) author + manage them.
  recurringInvoices       RecurringInvoice[] @relation("RecurringInvoiceCustomer")
  recurringInvoicesAuthored RecurringInvoice[] @relation("RecurringInvoiceAuthor")

  // Subcontractor compensation: bills the sub submits to us + the
  // accounting approver (any role).
  subcontractorBills    SubcontractorBill[] @relation("SubBillSubcontractor")
  subBillsApproved      SubcontractorBill[] @relation("SubBillApprover")
  subBillAttachments    SubcontractorBillAttachment[] @relation("SubBillAttachmentUploader")
  mileageEntries        MileageEntry[] @relation("MileageDriver")
  punchListItems        PunchListItem[] @relation("PunchListAuthor")
  galleryShares         GalleryShare[]  @relation("GalleryShareAuthor")
  satisfactionSurveys   SatisfactionSurvey[] @relation("SatisfactionSurveyCustomer")

  // Bidirectional messaging — staff can message customers and vice versa.
  // Cross-role permission (no customer↔customer) is enforced in the route.
  messagesSent     Message[] @relation("MessagesFromUser")
  messagesReceived Message[] @relation("MessagesToUser")

  // Employee/sub-side relations
  schedules     Schedule[]      @relation("AssignedSchedules")
  uploadedImages ProjectImage[] @relation("UploadedImages")
  uploadedDocuments ProjectDocument[] @relation("UploadedDocuments")
  logEntries    LogEntry[]
  boardPosts    MessageBoardPost[]
  invitesIssued Invitation[]    @relation("InvitesIssued")

  // Contracts
  contractTemplates ContractTemplate[] @relation("TemplateAuthor")
  contractsSent     Contract[]         @relation("ContractsCreated")
  contractsReceived Contract[]         @relation("ContractsForCustomer")

  // CRM / project management relations
  leadsOwned       Lead[]          @relation("LeadOwner")
  leadsCreated     Lead[]          @relation("LeadCreator")
  leadsConvertedTo Lead[]          @relation("LeadConvertedCustomer")
  leadActivities   LeadActivity[]
  projectsManaging Project[]       @relation("ProjectsManaging")
  projectComments  ProjectComment[]

  // Finance relations — kept here so expenses survive a user delete by
  // SetNull, with the audit trail intact.
  expensesPaid       Expense[] @relation("ExpensePaidBy")
  expensesSubmitted  Expense[] @relation("ExpenseSubmittedBy")

  // QuickBooks connections this user authorised (audit only — connection
  // can survive the user's deletion via SetNull).
  qbConnectionsConnected QbConnection[] @relation("QbConnectionsConnected")

  // Auth + audit
  passwordResets    PasswordResetToken[] @relation("PasswordResets")
  auditEventsActed  AuditEvent[]         @relation("AuditActor")

  // Estimates
  estimateTemplates EstimateTemplate[] @relation("EstimateTemplateAuthor")
  estimatesCreated  Estimate[]         @relation("EstimatesCreated")
  estimatesReceived Estimate[]         @relation("EstimatesForCustomer")

  // Time tracking
  timeEntries       TimeEntry[]        @relation("TimeEntries")
}

model Invitation {
  id          String   @id @default(cuid())
  email       String
  role        Role
  tokenHash   String   @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  invitedBy   User     @relation("InvitesIssued", fields: [invitedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([email])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  address     String?
  description String?
  status      ProjectStatus @default(PLANNING)
  customerId  String
  customer    User     @relation("CustomerProjects", fields: [customerId], references: [id])
  // Optional assigned PM. Cleared (SetNull) if the PM user is deleted so the
  // project record stays intact.
  projectManagerId String?
  projectManager   User?  @relation("ProjectsManaging", fields: [projectManagerId], references: [id], onDelete: SetNull)
  startDate   DateTime?
  endDate     DateTime?
  // Top-level project budget. Per-category line items live in ProjectBudgetLine
  // and supersede this number when present in the job-cost rollup.
  budgetCents Int?
  // Default false. When admin flips this on (e.g. cost-plus / open-book
  // engagements where the customer co-owns the budget), the customer can
  // see the project budget + the job-cost rollup. Otherwise both stay
  // strictly internal.
  showBudgetToCustomer Boolean @default(false)
  // Stamped when we email the customer a review-request after the project
  // is marked COMPLETE. Null = never sent. Keeps us from double-sending
  // when admin toggles status back and forth.
  reviewRequestSentAt DateTime?
  // Soft-archive timestamp. Archived projects fall out of default lists but
  // keep all their data; admins can unarchive at any time.
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schedules   Schedule[]
  invoices    Invoice[]
  selections  Selection[]
  images      ProjectImage[]
  documents   ProjectDocument[]
  logEntries  LogEntry[]
  contracts   Contract[]
  comments    ProjectComment[]
  expenses    Expense[]
  budgetLines ProjectBudgetLine[]
  // Optional back-link to the estimate that birthed this project (null
  // until an estimate is converted; never re-bound).
  estimatesConverted Estimate[] @relation("ProjectFromEstimate")
  timeEntries        TimeEntry[]
  changeOrders       ChangeOrder[]
  recurringInvoices  RecurringInvoice[]
  subcontractorBills SubcontractorBill[]
  bankRules          BankCategorizationRule[]
  mileageEntries     MileageEntry[]
  punchListItems     PunchListItem[]
  galleryShares      GalleryShare[]
  satisfactionSurvey SatisfactionSurvey?

  @@index([projectManagerId])
}

model Schedule {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?    @relation("AssignedSchedules", fields: [assigneeId], references: [id])
  title       String
  notes       String?
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())

  @@index([startsAt])
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  customerId  String
  customer    User          @relation(fields: [customerId], references: [id])
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id])
  amountCents Int
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime      @default(now())
  dueAt       DateTime?
  paidAt      DateTime?
  notes       String?
  lineItems   Json?
  // Hosted-payment URL (Stripe payment link, QuickBooks, Square, etc.).
  // Set by the admin; rendered as a "Pay now" button on the customer side.
  paymentUrl  String?
  // Set by the reminder cron after each successful nudge — used to keep one
  // invoice from getting emailed every day. Null means never reminded.
  lastReminderAt DateTime?
  // When true, the customer must acknowledge the milestone (typed name
  // signature) before any payment "Pay now" affordances appear. Used for
  // progress-billing draws so the customer can't pay (and then later say
  // they didn't agree the work was complete). Free-text milestoneLabel is
  // surfaced to the customer above the signature box. Null acknowledgedAt
  // means "not yet signed".
  requiresAcknowledgment Boolean   @default(false)
  milestoneLabel         String?
  acknowledgedAt         DateTime?
  acknowledgedName       String?
  acknowledgedIp         String?
  payments    Payment[]
  // Back-link populated when an invoice was auto-issued from an accepted
  // change order. Null for ordinary invoices.
  changeOrder ChangeOrder?
}

// One row per payment received against an invoice. Most invoices get one
// payment (a check, a Zelle transfer); partial payments stack as multiple
// rows. The invoice status flips to PAID automatically when the sum of
// payment amounts hits the invoice total — the recompute helper lives in
// server/src/lib/payments.ts so the API and the Stripe webhook share it.
model Payment {
  id              String        @id @default(cuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amountCents     Int
  method          PaymentMethod
  // Free-text reference: check number, Zelle confirmation code, ACH trace
  // number, Stripe payment_intent id, etc. Indexed so admins can search a
  // bounced check or duplicate transfer fast.
  referenceNumber String?
  receivedAt      DateTime      @default(now())
  notes           String?
  recordedById    String?
  recordedBy      User?         @relation("RecordedPayments", fields: [recordedById], references: [id])
  createdAt       DateTime      @default(now())

  // Optional bank-transaction backlink — set when admin matches the bank
  // line to this payment so the P&L doesn't double-count the deposit.
  bankTransactions BankTransaction[]

  @@index([invoiceId])
  @@index([referenceNumber])
}

// Mileage log — one row per trip, deductible at the IRS standard rate.
// userId is who drove; projectId is the job they drove for (null for
// general business overhead — supply runs, banking, etc). rateCentsPerMile
// snapshots the IRS rate at log time so changing the rate later doesn't
// retroactively shift every total. We store BOTH miles and the computed
// total to keep the rollup endpoint cheap.
model MileageEntry {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("MileageDriver", fields: [userId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  date            DateTime
  // Stored as a Decimal-safe Int so 12.3 miles = 123 (we use tenths). Avoids
  // float drift across thousands of trips at year-end.
  milesTenths     Int
  // 1 cent precision on the rate so 67.0 cents = 670. Multiplied by miles
  // and divided back by 1000 to land on cents.
  rateCentsPerMile Int
  totalCents      Int
  purpose         String?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([userId, date])
  @@index([projectId])
}

// One-row table that holds company-wide settings the admin edits from the
// portal: business contact info + the payment instructions that show on
// every unpaid invoice (Zelle handle, ACH details, who to make checks out
// to, where to mail them). All fields are optional; the UI just hides any
// section that's blank so we don't tell customers "Pay via Zelle: " with
// nothing after it.
//
// We pin the row to id = "default" so the upsert pattern stays trivial.
model CompanySettings {
  id                  String   @id @default("default")
  // Business identity
  companyName         String?
  legalName           String?
  taxId               String?
  phone               String?
  email               String?
  websiteUrl          String?
  // Mailing address (rendered on receipts + invoices)
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  zip                 String?
  // Payment instructions — all optional. Empty fields are hidden.
  zelleEmail          String?
  zelleName           String?
  zellePhone          String?
  achInstructions     String?
  checkPayableTo      String?
  checkMailingAddress String?
  // Free-form note shown above the payment options ("we accept …", "deposits
  // due in cash on day-of", etc.).
  paymentNotes        String?
  // Optional review-request URLs. When the project COMPLETE email goes out
  // we include any URL that's set; blank ones are skipped.
  googleReviewUrl     String?
  yelpReviewUrl       String?
  // IRS standard mileage rate, in cents per mile (e.g. 67.0¢ → 670). Admin
  // sets this when the rate changes; mileage entries snapshot whichever
  // value was current at log time. Defaults to 670 (2025 IRS rate).
  mileageRateCents    Int      @default(670)
  updatedAt           DateTime @updatedAt
}

// Signed addendum to a project's contract that bumps (or reduces) the
// scope and price. Customers see DRAFT change orders as informational and
// SENT ones as actionable (sign or decline). When ACCEPTED, the server
// auto-issues a DRAFT invoice for the change amount linked to the same
// project so accounting doesn't have to remember.
//
// amountCents is signed: positive = additional bill to the customer,
// negative = credit / scope reduction. Receipts and invoices honor the
// sign so a $-500 change order produces a $-500 invoice the customer
// gets credit on the next draw.
model ChangeOrder {
  id             String              @id @default(cuid())
  number         String              @unique
  projectId      String
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Optional link back to the parent contract this is amending; null is
  // valid (project may not have a stored contract record).
  contractId     String?
  contract       Contract?           @relation(fields: [contractId], references: [id])
  title          String
  description    String?
  amountCents    Int
  status         ChangeOrderStatus   @default(DRAFT)
  createdById    String
  createdBy      User                @relation("ChangeOrdersAuthored", fields: [createdById], references: [id])
  createdAt      DateTime            @default(now())
  sentAt         DateTime?
  // Customer signoff (typed name + IP) when status flips to ACCEPTED.
  signatureName  String?
  signatureIp    String?
  signedAt       DateTime?
  declinedAt     DateTime?
  declineReason  String?
  // The auto-issued invoice id when accepted (null until then). Lets us
  // surface "view invoice" instead of "create invoice" once it's done.
  invoiceId      String?            @unique
  invoice        Invoice?           @relation(fields: [invoiceId], references: [id])
  updatedAt      DateTime            @updatedAt

  @@index([projectId])
  @@index([status])
}

enum ChangeOrderStatus {
  // Customer-initiated request (no price yet). Admin quotes → DRAFT.
  REQUESTED
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  VOID
}

// Recurring invoice template. The cron checks every active row whose
// nextRunAt <= now, creates a DRAFT invoice from the template (carrying
// over amount + notes + lineItems), then advances nextRunAt by one
// frequency unit. Pause by flipping active=false; admin still sees the
// row so they can resume later. Optional endsAt stops the schedule
// after a fixed date.
model RecurringInvoice {
  id           String              @id @default(cuid())
  customerId   String
  customer     User                @relation("RecurringInvoiceCustomer", fields: [customerId], references: [id])
  projectId    String?
  project      Project?            @relation(fields: [projectId], references: [id])
  label        String              // human description: "Monthly maintenance"
  amountCents  Int
  frequency    RecurringFrequency
  // For MONTHLY/QUARTERLY/YEARLY: 1..28 (we cap at 28 to dodge end-of-month
  // ambiguity). For WEEKLY: 0..6 (Sunday=0). Ignored for DAILY.
  dayOfPeriod  Int?
  notes        String?
  lineItems    Json?
  active       Boolean             @default(true)
  nextRunAt    DateTime
  lastRunAt    DateTime?
  // Optional auto-stop date — past this we mark inactive on the next run.
  endsAt       DateTime?
  createdById  String
  createdBy    User                @relation("RecurringInvoiceAuthor", fields: [createdById], references: [id])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([active, nextRunAt])
}

// A bill the company OWES to a subcontractor — the inverse of customer
// invoices. Sub uploads (or admin enters) it, accounting approves, then
// marks paid. On PAID we automatically write an Expense row tagged to
// the same project so it shows up as Cost-of-Goods-Sold in the job-cost
// rollup. The auto-created expense's id is stored back on the bill so
// admin can navigate or unwind cleanly.
model SubcontractorBill {
  id              String                  @id @default(cuid())
  number          String                  @unique           // SB-YYYY-####
  // Sub's own invoice number (their reference) — not unique across subs.
  externalNumber  String?
  subcontractorId String
  subcontractor   User                    @relation("SubBillSubcontractor", fields: [subcontractorId], references: [id])
  projectId       String?
  project         Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  amountCents     Int
  status          SubcontractorBillStatus @default(PENDING)
  receivedAt      DateTime                @default(now())
  approvedAt      DateTime?
  approvedById    String?
  approvedBy      User?                   @relation("SubBillApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  paidAt          DateTime?
  paidMethod      PaymentMethod?
  paidReference   String?
  notes           String?
  // Pointer to the auto-issued expense row so we can find/remove it on
  // status change. Null until PAID.
  expenseId       String?                 @unique
  expense         Expense?                @relation("SubBillExpense", fields: [expenseId], references: [id])
  attachments     SubcontractorBillAttachment[]
  bankTransactions BankTransaction[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([subcontractorId])
  @@index([projectId])
  @@index([status])
}

// One row per uploaded file backing a SubcontractorBill — the sub's own
// invoice as a PDF or photo, plus optional photos of the work itself.
// Stored on the same disk/S3 backend as project images so we don't fork
// the storage logic.
model SubcontractorBillAttachment {
  id              String            @id @default(cuid())
  billId          String
  bill            SubcontractorBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  uploadedById    String
  uploadedBy      User              @relation("SubBillAttachmentUploader", fields: [uploadedById], references: [id])
  filename        String            // original filename
  url             String            // public URL we serve
  thumbnailUrl    String?           // present for images
  contentType     String            // mime
  sizeBytes       Int
  createdAt       DateTime          @default(now())

  @@index([billId])
}

enum SubcontractorBillStatus {
  PENDING       // received, not yet approved
  APPROVED      // accounting OK'd; ready to pay
  PAID          // money out the door + expense row written
  VOID          // rejected or cancelled
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// A bank account, credit card, cash drawer, or any other place money sits.
// Used for both balance-sheet asset rollup and bank-transaction tracking.
// kind drives whether the balance shows as an asset or a liability:
//   CHECKING / SAVINGS / CASH = asset (positive balance is good)
//   CREDIT_CARD / LINE_OF_CREDIT = liability (positive balance = we owe)
//   LOAN = liability
//   OTHER = asset by default; admin can flip with isLiability.
//
// currentBalanceCents is the admin-edited "as of today" balance — used by
// the balance sheet and updated when bank transactions are imported. We
// don't recompute from transactions because partial history (CSV doesn't
// usually go back to account opening) would always under-count.
model BankAccount {
  id                  String   @id @default(cuid())
  name                String
  kind                BankAccountKind @default(CHECKING)
  // Last 4 of the account number — purely cosmetic so the dropdown reads as
  // 'Chase Checking ··1234' instead of 'Chase Checking'.
  last4               String?
  institutionName     String?
  // Cents in the account today. For credit cards / loans this is the
  // amount owed (positive = liability balance).
  currentBalanceCents Int      @default(0)
  // Override the default asset/liability classification. When true the
  // account is rolled up under Liabilities even if its kind is normally
  // an asset (e.g. a 'Cash' kind that's actually a tenant escrow).
  isLiability         Boolean  @default(false)
  active              Boolean  @default(true)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  transactions        BankTransaction[]
  rules               BankCategorizationRule[]
}

enum BankAccountKind {
  CHECKING
  SAVINGS
  CASH
  CREDIT_CARD
  LINE_OF_CREDIT
  LOAN
  OTHER
}

// One row per bank-statement line. Imported via CSV or entered manually;
// admin can edit any field after the fact (matching how QB lets you mutate
// transaction data freely). amountCents is signed: positive = money in,
// negative = money out.
//
// matchedExpenseId / matchedPaymentId / matchedSubBillId tie the bank
// transaction to an existing record so the P&L doesn't double-count. When
// none are set the row's category drives the P&L bucket directly.
model BankTransaction {
  id              String   @id @default(cuid())
  accountId       String
  account         BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date            DateTime
  // The signed cents amount. Positive = inflow (deposit / credit), negative
  // = outflow (debit / charge). Matches the convention most US bank exports
  // already follow.
  amountCents     Int
  description     String   // free text from the statement memo
  // Optional explicit running balance from the statement at this row's date.
  // Useful for reconciliation but not required.
  runningBalanceCents Int?
  // Free-text category (matches our Expense category model). Auto-set by
  // categorization rules on import; admin can override.
  categoryId      String?
  category        ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  // Manual reconciliation marker — flipped when admin confirms the line
  // matches the statement. Independent of matched* below (a row can be
  // reconciled without being tied to a portal record, e.g. a bank fee).
  reconciled      Boolean  @default(false)
  reconciledAt    DateTime?
  // At most one of these three is non-null (we don't enforce that at the DB
  // level — admin overrides should be cheap). When set, the transaction is
  // already represented by the matched record so the P&L uses the matched
  // record's classification, not the transaction's category.
  matchedPaymentId   String?
  matchedPayment     Payment?           @relation(fields: [matchedPaymentId], references: [id], onDelete: SetNull)
  matchedExpenseId   String?
  matchedExpense     Expense?           @relation(fields: [matchedExpenseId], references: [id], onDelete: SetNull)
  matchedSubBillId   String?
  matchedSubBill     SubcontractorBill? @relation(fields: [matchedSubBillId], references: [id], onDelete: SetNull)
  // External id from the bank export — used for dedupe so re-importing
  // the same CSV doesn't duplicate rows. Optional because some exports
  // don't include one.
  externalId      String?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([accountId, date])
  @@index([accountId, externalId])
  @@index([categoryId])
}

// Auto-categorization rule applied at CSV import time. matches descriptions
// case-insensitively (substring match keeps it simple — most bank memos are
// uppercase, predictable, and verbose enough that 'HOME DEPOT' will catch
// 'PURCHASE - HOME DEPOT #1234 ANYTOWN'). When accountId is null the rule
// applies to every account; otherwise scoped.
model BankCategorizationRule {
  id          String   @id @default(cuid())
  accountId   String?
  account     BankAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  // Substring matched against transaction description (case-insensitive).
  matchText   String
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  // Optional vendor + project pre-fills so a 'HOME DEPOT' rule can also
  // tag the row with a vendor row admin already maintains.
  vendorId    String?
  vendor      Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId])
  @@index([categoryId])
}

// Owned non-cash assets — vehicles, tools, equipment, real estate. Kept
// dead-simple: a name, an acquisition cost (or current value override),
// optional acquired date. No depreciation engine — admin fills in the
// current value when it changes (matching the user's stated workflow of
// editing data manually rather than relying on accounting automation).
//
// All non-archived rows roll up to the balance sheet's Assets section.
model OtherAsset {
  id              String   @id @default(cuid())
  name            String
  category        String?  // free-text: Vehicle, Tools, Real estate, etc.
  // The current book value used by the balance sheet. Admin sets this
  // directly — no depreciation calc.
  currentValueCents Int    @default(0)
  acquiredAt      DateTime?
  acquisitionCostCents Int?
  notes           String?
  archived        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Standalone liabilities not represented by a BankAccount (long-term
// loans the company owes, vendor payables in aggregate, etc.). Same flat
// shape as OtherAsset.
model OtherLiability {
  id              String   @id @default(cuid())
  name            String
  category        String?  // free-text: Loan, Equipment lease, Tax payable, etc.
  currentBalanceCents Int  @default(0)
  notes           String?
  archived        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum PaymentMethod {
  CASH
  CHECK
  ZELLE
  ACH
  WIRE
  CARD
  STRIPE
  QUICKBOOKS
  OTHER
}

model Selection {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customerId  String
  customer    User            @relation(fields: [customerId], references: [id])
  category    String
  option      String
  notes       String?
  status      SelectionStatus @default(PENDING)
  decidedAt   DateTime?
  createdAt   DateTime        @default(now())
}

model Membership {
  id           String         @id @default(cuid())
  customerId   String         @unique
  customer     User           @relation(fields: [customerId], references: [id])
  tier         MembershipTier @default(STANDARD)
  startedAt    DateTime       @default(now())
  renewsAt     DateTime?
  active       Boolean        @default(true)
}

model ProjectImage {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy  User     @relation("UploadedImages", fields: [uploadedById], references: [id])
  filename    String
  url         String
  thumbnailUrl String?
  caption     String?
  // Optional phase tag so the timeline view can group photos by stage.
  // Free of an enum so the team can add their own (e.g. "PUNCH").
  phase       String?
  // Optional taken-at timestamp distinct from createdAt — admin can edit
  // this when uploading older photos so the timeline reflects when the
  // shot was taken, not when it was uploaded. Defaults to createdAt at
  // read time when null.
  takenAt     DateTime?
  createdAt   DateTime @default(now())

  @@index([projectId, takenAt])
}

// Customer satisfaction survey — one auto-issued ~14 days after a project
// flips to COMPLETE. The customer follows a token URL (no portal login
// required) and submits an NPS-style 0–10 score + optional comments.
// Admin sees responses on a finance/satisfaction dashboard. Surveys
// without a score yet show as 'pending'.
model SatisfactionSurvey {
  id          String    @id @default(cuid())
  projectId   String    @unique
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customerId  String
  customer    User      @relation("SatisfactionSurveyCustomer", fields: [customerId], references: [id])
  // SHA-256 of the link token; raw value lives in the URL only.
  tokenHash   String    @unique
  // Set when the cron emails the customer.
  sentAt      DateTime?
  // Customer-supplied fields. score is 0–10 NPS; nps category derived in
  // the rollup, not stored.
  score       Int?
  comments    String?
  // What can we do better — separate field so positive/negative split
  // stays legible for admin.
  improvements String?
  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sentAt])
  @@index([submittedAt])
}

// Time-limited public share link for a project's photo gallery. Customer
// generates one (or admin) and forwards the URL to friends/family without
// requiring them to log into the portal. We store only the SHA-256 of
// the token so a leaked DB row doesn't grant access; the raw token rides
// in the URL. expiresAt + revokedAt let admin pull the plug.
model GalleryShare {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // SHA-256 hex of the random token; the raw value lives only in the URL.
  tokenHash   String    @unique
  // Optional friendly label so admin can tell two links apart in the UI
  // ("Sent to Mom 4/26", "For Houzz feature").
  label       String?
  createdById String
  createdBy   User      @relation("GalleryShareAuthor", fields: [createdById], references: [id])
  expiresAt   DateTime
  revokedAt   DateTime?
  // Bumped every time the public page loads so admin can see traction.
  viewCount   Int       @default(0)
  lastViewedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([projectId])
}

// Walk-through punch-list item — one per task remaining at substantial
// completion. Customer reviews each item and either signs off (DONE) or
// flags an issue (REOPENED). Staff resolve REOPENED items and re-mark them
// READY_FOR_REVIEW so the customer can re-confirm.
//
// Signature capture is per-item: customer types their name + we stamp IP +
// timestamp when they mark DONE. order is admin-controlled so the list
// reads in walk-through order, not alphabetical.
model PunchListItem {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description     String
  notes           String?
  // Optional room / area tag so the list groups naturally on the customer
  // walk-through ('Kitchen', 'Master bath', etc.).
  area            String?
  status          PunchListStatus @default(OPEN)
  position        Int           @default(0)
  createdById     String
  createdBy       User          @relation("PunchListAuthor", fields: [createdById], references: [id])
  // Customer signoff fields — populated when status flips to DONE.
  signedAt        DateTime?
  signatureName   String?
  signatureIp     String?
  // When the customer reopens an item with a reason, we keep the latest
  // reason here for staff to triage.
  reopenedAt      DateTime?
  reopenReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([projectId, position])
}

enum PunchListStatus {
  OPEN              // staff is still working on it
  READY_FOR_REVIEW  // staff thinks it's done; awaiting customer signoff
  DONE              // customer signed off
  REOPENED          // customer pushed back; staff to address again
}

// Non-photo project documents: permits, drawings, manuals, specs, etc.
// Lives next to ProjectImage so customers and staff have a single
// project page that bundles everything visible. category is free-text
// (with the UI surfacing a small list of common values) so teams can
// add their own without a schema change.
model ProjectDocument {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  filename     String
  url          String
  contentType  String
  sizeBytes    Int
  // permit / drawing / manual / spec / warranty / other — free-text.
  category     String?
  description  String?
  // Customer-visible? Defaults true (most documents we want to share);
  // admin can flip to false on internal-only files (e.g. cost worksheets).
  customerVisible Boolean @default(true)
  createdAt    DateTime @default(now())

  @@index([projectId, category])
}

model LogEntry {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  body        String
  createdAt   DateTime @default(now())
}

model MessageBoardPost {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  title     String
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Message {
  id          String   @id @default(cuid())
  fromUserId  String
  fromUser    User     @relation("MessagesFromUser", fields: [fromUserId], references: [id])
  toUserId    String
  toUser      User     @relation("MessagesToUser", fields: [toUserId], references: [id])
  subject     String?
  body        String
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([toUserId])
  @@index([fromUserId])
}

model ContractTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  // Body is a string with {{variable}} placeholders. Plain text or markdown.
  body        String
  // List of variable definitions: [{ key, label, required, multiline }, ...]
  variables   Json     @default("[]")
  active      Boolean  @default(true)
  // When true, accepting an estimate automatically spawns a project +
  // a draft contract from this template, so the customer doesn't have to
  // wait on sales for the conversion. At most one template should carry
  // this flag — the route enforces that on save.
  isDefaultForEstimateAccept Boolean @default(false)
  createdById String
  createdBy   User     @relation("TemplateAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contracts   Contract[]
}

model Contract {
  id           String         @id @default(cuid())
  templateId   String?
  template     ContractTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  // Optional link back to the project this contract is for. Lets us list
  // signed contracts on the project hub and audit which agreements gate
  // which work. SetNull on project delete to preserve the contract record.
  projectId    String?
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Snapshots — preserved when the underlying template changes or is deleted
  // so what the customer signed is the body that was sent, regardless of
  // future template edits.
  templateNameSnapshot String
  bodySnapshot         String
  variableValues       Json @default("{}")

  customerId   String
  customer     User           @relation("ContractsForCustomer", fields: [customerId], references: [id])
  createdById  String
  createdBy    User           @relation("ContractsCreated", fields: [createdById], references: [id])

  status       ContractStatus @default(DRAFT)
  sentAt       DateTime?
  viewedAt     DateTime?
  signedAt     DateTime?
  declinedAt   DateTime?

  // Lightweight typed-name signature with audit metadata. Not legally
  // equivalent to a notarised e-sig service, but enough for soft-signoff
  // construction agreements; swap to DocuSign/Dropbox Sign later if needed.
  signatureName String?
  signatureIp   String?
  declineReason String?

  // Last time we nudged the customer about this open contract — used to
  // throttle reminders so we don't email more than once per day.
  lastReminderAt DateTime?

  // Delivery channel used to collect the customer's signature.
  // PORTAL: typed-name signature inside our app (default).
  // DOCUSIGN: contract is sent through a DocuSign envelope; status is
  // updated by webhook events and the typed-name fields stay null.
  delivery     ContractDelivery @default(PORTAL)
  docusignEnvelopeId String?
  docusignStatus     String?

  // Back-link to the estimate this contract was spawned from, when one
  // exists. Independent of project link (the estimate may have created
  // both the contract and the project at conversion time).
  estimatesConverted Estimate[] @relation("ContractFromEstimate")
  changeOrders       ChangeOrder[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([customerId])
  @@index([createdById])
  @@index([status])
}

model Lead {
  id            String     @id @default(cuid())
  name          String
  email         String?
  phone         String?
  address       String?
  // Brief description of what they want done, scope of work, etc.
  scope         String?
  estimatedValueCents Int?
  status        LeadStatus @default(NEW)
  source        LeadSource @default(OTHER)

  // Sales rep this lead is assigned to. Optional so freshly imported leads
  // can sit in the pool until someone claims them.
  ownerId       String?
  owner         User?      @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdById   String
  createdBy     User       @relation("LeadCreator", fields: [createdById], references: [id])

  // Set when the lead is converted to a customer account (via invitation).
  convertedAt           DateTime?
  convertedToCustomerId String?
  convertedToCustomer   User?     @relation("LeadConvertedCustomer", fields: [convertedToCustomerId], references: [id])

  notes         String?
  activities    LeadActivity[]
  estimates     Estimate[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([ownerId])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  // Free-form type tag: "note", "call", "email", "meeting", "status_change".
  // Keeping as string instead of an enum so the team can add new categories
  // without a migration.
  type      String
  body      String
  createdAt DateTime @default(now())

  @@index([leadId])
}

// Project-level threaded discussion visible to the customer + assigned PM
// + admin. Distinct from one-to-one Messages because the audience is the
// project participants rather than two specific users.
model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  // Optional attachments (images for now): [{url, thumbnailUrl, filename}].
  // Stored as JSON so adding more attachment metadata later (mime type,
  // bytes) doesn't require a migration.
  attachments Json?
  createdAt DateTime @default(now())

  @@index([projectId])
}

// Vendor — a supplier or service provider an expense is paid to. Local-only
// by default; qbVendorId is populated once the QB integration syncs the
// record. Deleting a vendor sets the FK on its expenses to null instead of
// cascading so historical expenses don't disappear.
model Vendor {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  notes       String?
  active      Boolean  @default(true)
  qbVendorId  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses    Expense[]
  products    Product[]
  bankRules   BankCategorizationRule[]

  @@index([name])
}

// ExpenseCategory — a chart-of-accounts node. parentId allows a flat or
// nested taxonomy ("Materials > Lumber"). qbAccountId is the QBO mapping,
// only populated when integrated. Soft archive via active=false instead of
// hard delete.
model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String
  parentId    String?
  parent      ExpenseCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ExpenseCategory[] @relation("CategoryTree")
  active      Boolean  @default(true)
  qbAccountId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses    Expense[]
  budgetLines ProjectBudgetLine[]
  bankTransactions BankTransaction[]
  bankRules   BankCategorizationRule[]

  @@index([parentId])
}

// Expense — every receipt, bill, or reimbursable. Receipt image is optional
// because not every entry will have one (e.g. a recurring rent bill). The
// integration columns (qb*) are nullable so the model works fine with no
// QuickBooks connection ever.
model Expense {
  id          String   @id @default(cuid())
  vendorId    String?
  vendor      Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  categoryId  String?
  category    ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Optional links so expense rolls up under a project / lead in dashboards.
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Two user pointers — who paid out of pocket vs who entered the record.
  // Both are nullable so a deleted user doesn't drop their expenses.
  paidByUserId    String?
  paidBy          User?  @relation("ExpensePaidBy", fields: [paidByUserId], references: [id], onDelete: SetNull)
  submittedById   String?
  submittedBy     User?  @relation("ExpenseSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)

  amountCents Int
  date        DateTime
  description String?
  notes       String?
  reimbursable Boolean @default(false)
  reimbursedAt DateTime?

  receiptUrl          String?
  receiptThumbnailUrl String?

  // Integration: tracks whether this expense has been pushed to an external
  // accounting system. Always populated; default LOCAL_ONLY so the app works
  // identically with or without a QB connection.
  syncStatus     ExpenseSyncStatus @default(LOCAL_ONLY)
  qbExpenseId    String?           @unique
  lastSyncAttemptAt DateTime?
  lastSyncError  String?

  // Optional back-link populated when the expense was auto-created from
  // a SubcontractorBill being marked PAID.
  subcontractorBill SubcontractorBill? @relation("SubBillExpense")
  bankTransactions BankTransaction[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([categoryId])
  @@index([vendorId])
  @@index([paidByUserId])
  @@index([syncStatus])
}

// One row per category-level budget on a project. Optional categoryId so
// "general / unscoped" budget lines are still tracked; uniqueness on
// (projectId, categoryId) prevents accidental duplicates per category.
model ProjectBudgetLine {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  budgetCents Int
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, categoryId])
  @@index([projectId])
}

// QuickBooks Online connection. Singleton in practice (one per company),
// but no DB-level uniqueness enforced — the route layer always uses the
// most-recent active row. Tokens are stored in plaintext; you should
// migrate to KMS-encrypted columns before going to production.
model QbConnection {
  id                  String   @id @default(cuid())
  realmId             String   @unique
  accessToken         String
  refreshToken        String
  // Both expirations come from Intuit at exchange time. The access token
  // typically lasts 1 hour and the refresh token rolls every 100 days.
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  scope               String?
  connectedById       String?
  connectedBy         User?    @relation("QbConnectionsConnected", fields: [connectedById], references: [id], onDelete: SetNull)
  lastError           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Single-use password reset token. Mirrors Invitation: only the SHA-256
// hash is stored, the raw value lives in the email link. Expires in 1h
// (much shorter than invites; resets are higher-risk).
model PasswordResetToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("PasswordResets", fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// Audit event — append-only log of sensitive writes. We never delete from
// this table from the app; rotate on the DB side once it gets large.
model AuditEvent {
  id          String   @id @default(cuid())
  // Caller info — actorId is optional so we can record events that happen
  // without an authenticated session (e.g. password reset request).
  actorId     String?
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorRole   String?
  // What happened. Free-text but encouraged: "user.role_changed",
  // "contract.voided", "expense.deleted", "qb.disconnected", etc.
  action      String
  // Resource pointer for filtering. resourceType + resourceId are nullable
  // so non-resource events (e.g. login_failed) still record.
  resourceType String?
  resourceId   String?
  // Free-form payload (request IP, before/after diff, message). Kept as
  // JSON so we don't have to migrate every time we record a new field.
  meta        Json?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([resourceType, resourceId])
  @@index([actorId])
  @@index([createdAt])
}

enum EstimateStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  CONVERTED
  VOID
}

// EstimateTemplate — admin-curated starter pack of line items for a common
// scope (e.g. "Composite deck install", "Bathroom remodel — 5x8"). Sales
// reps pick one, fill in quantities, adjust prices, and add custom lines.
// Lines on the template are copied into the Estimate at draft time so
// later template edits don't mutate sent estimates.
model EstimateTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  // Optional category for grouping in the template picker — "Decks",
  // "Bathrooms", "Hardscape", etc.
  category    String?
  active      Boolean  @default(true)
  createdById String
  createdBy   User     @relation("EstimateTemplateAuthor", fields: [createdById], references: [id])
  lines       EstimateTemplateLine[]
  estimates   Estimate[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EstimateTemplateLine {
  id          String   @id @default(cuid())
  templateId  String
  template    EstimateTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  description String
  // Default quantity. Stored as Decimal so half-units (yards, hours) are
  // honest — Prisma exposes Decimal as string in the JSON envelope.
  defaultQuantity Decimal @db.Decimal(12, 3) @default(0)
  unit        String?  // "ea", "lf", "sqft", "cuyd", "hr", "lump", etc.
  unitPriceCents Int @default(0)
  // Optional sub-totaling category for the rep view: "Materials", "Labor",
  // "Permits", "Disposal".
  category    String?
  notes       String?
  position    Int @default(0)
}

model Estimate {
  id          String   @id @default(cuid())
  number      String   @unique  // EST-YYYY-####
  status      EstimateStatus @default(DRAFT)

  // Either a converted customer or a still-a-lead. At least one should be
  // set; both can be set after a lead converts during the estimate's life.
  customerId  String?
  customer    User?    @relation("EstimatesForCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  templateId  String?
  template    EstimateTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateNameSnapshot String?

  createdById String
  createdBy   User     @relation("EstimatesCreated", fields: [createdById], references: [id])

  title       String
  scope       String?  // free-text scope shown on the customer-facing view
  notes       String?  // internal notes
  termsText   String?

  // Pricing — totals are persisted (rather than recalculated each request)
  // so historical estimates are immune to later price-list edits.
  subtotalCents Int @default(0)
  taxRateBps  Int @default(0) // 700 = 7.00%
  taxCents    Int @default(0)
  totalCents  Int @default(0)

  validUntil  DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?
  acceptedAt  DateTime?
  declinedAt  DateTime?
  declineReason String?
  acceptedBySignature String?
  acceptedByIp String?

  // What this estimate became when accepted + converted.
  convertedProjectId  String?
  convertedProject    Project? @relation("ProjectFromEstimate", fields: [convertedProjectId], references: [id], onDelete: SetNull)
  convertedContractId String?
  convertedContract   Contract? @relation("ContractFromEstimate", fields: [convertedContractId], references: [id], onDelete: SetNull)

  lines       EstimateLine[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([leadId])
}

model EstimateLine {
  id          String   @id @default(cuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(12, 3) @default(0)
  unit        String?
  unitPriceCents Int @default(0)
  // Pre-computed = round(quantity * unitPriceCents). Kept on the row so
  // the customer-facing view doesn't redo math client-side.
  totalCents  Int @default(0)
  category    String?
  notes       String?
  position    Int @default(0)
}

// Product — a single SKU in the catalog. Materials, labor units, fees, etc.
// Sales reps and PMs reach for these when building an estimate; admin curates.
// Optional vendor link surfaces vendor-specific pricing later.
model Product {
  id              String   @id @default(cuid())
  // SKU is optional for simple internal items; unique when provided.
  sku             String?  @unique
  name            String
  description     String?
  // What this product *is*. Free-form so the catalog isn't wedged into a
  // fixed enum; common values: "material", "labor", "fee", "subcontract".
  kind            String   @default("material")
  unit            String?  // "ea", "lf", "sqft", "cuyd", "hr", "lump"
  defaultUnitPriceCents Int @default(0)
  // Optional category mirrors ExpenseCategory naming so estimate→budget
  // flow groups cleanly.
  category        String?
  vendorId        String?
  vendor          Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  active          Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assemblyLines   AssemblyLine[]

  @@index([category])
  @@index([kind])
}

// Assembly — a named bundle of products (or sub-assemblies) that maps to a
// real-world scope: "Composite deck install — 16x20", "Bathroom rough-in",
// "Hardscape patio — 200 sqft pavers". Sales reps drop an assembly onto an
// estimate and get all its line items at once.
//
// Distinct from EstimateTemplate: a template is a whole-estimate skeleton
// (header + lines + terms), an assembly is a reusable group of lines that
// can be inserted into multiple templates or directly into a draft estimate.
model Assembly {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?  // "Decks", "Bathrooms", "Hardscape" — same taxonomy as templates
  active      Boolean  @default(true)
  // Optional cover image for the catalog UI (a thumbnail in the picker).
  imageUrl    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines       AssemblyLine[]
  // Lines that reference this assembly as a sub-assembly.
  parentLines AssemblyLine[] @relation("AssemblySubLines")

  @@index([category])
}

// AssemblyLine — one entry in an assembly. Discriminated by the *Id columns:
//   * productId set, subAssemblyId null  → product line
//   * productId null,  subAssemblyId set  → nested assembly (expanded recursively
//                                            at insertion time)
//   * both null                          → freeform line (description + price)
//
// Cycle prevention is the route layer's job.
model AssemblyLine {
  id            String   @id @default(cuid())
  assemblyId    String
  assembly      Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  subAssemblyId String?
  subAssembly   Assembly? @relation("AssemblySubLines", fields: [subAssemblyId], references: [id], onDelete: SetNull)

  // For product lines: quantity multiplies product.defaultUnitPriceCents.
  // For sub-assembly lines: quantity multiplies the rolled-up sub total.
  // For freeform lines: quantity * unitPriceOverrideCents.
  quantity      Decimal @db.Decimal(12, 3) @default(0)
  // Optional override so a particular assembly can carry a different price
  // than the catalog default (e.g. negotiated bulk rate for a recurring scope).
  unitPriceOverrideCents Int?
  // Freeform lines need their own description; product/sub lines fall back
  // to the referenced row's name when this is null.
  description   String?
  category      String?  // overrides the product/assembly's default category
  notes         String?
  position      Int @default(0)

  @@index([assemblyId])
}

// TimeEntry — per-user labor on a project. Used for two things:
//   1. Payroll prep: total hours × hourly rate per user per pay period.
//   2. Job-cost rollup: labor cost vs. budgeted Labor category.
//
// Punch-in/out style: startedAt always set; endedAt null while clocked in.
// minutes is denormalised (computed when endedAt is set) so reports don't
// recompute on every read.
model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("TimeEntries", fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  startedAt   DateTime
  endedAt     DateTime?
  minutes     Int @default(0)

  // Snapshot of the hourly rate at recording time so historical labor cost
  // is immune to later rate changes.
  hourlyRateCents Int @default(0)
  // Whether the time is billable to the project (vs internal/admin time).
  billable    Boolean @default(true)
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([startedAt])
}
